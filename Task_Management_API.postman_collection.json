{
	"info": {
		"_postman_id": "890fae13-68d1-4db8-8bbf-8547a46f7311",
		"name": "Taskly Task Management API",
		"description": "API collection for the Task Management Application. Includes user authentication and CRUD operations for tasks.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.token) {",
									"    pm.globals.set(\"token\", jsonData.data.token);",
									"    console.log(\"Auth token saved to global variables!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Registers a new user and automatically saves their JWT token into the global variable `token` for subsequent authenticated requests."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.token) {",
									"    pm.globals.set(\"token\", jsonData.data.token);",
									"    console.log(\"Auth token saved to global variables!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"jane@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Authenticates user credentials and automatically saves the returned JWT token to global variable `token`."
					},
					"response": []
				},
				{
					"name": "Get User Profile",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"me"
							]
						},
						"description": "Retrieves the authenticated user's profile details based on the stored JWT token."
					},
					"response": []
				}
			]
		},
		{
			"name": "Tasks",
			"item": [
				{
					"name": "Get All Tasks",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/tasks?search=&status=All&priority=All&sortBy=dueDate:asc",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tasks"
							],
							"query": [
								{
									"key": "search",
									"value": "",
									"description": "Optional search string matching task title or description"
								},
								{
									"key": "status",
									"value": "All",
									"description": "All, Pending, In Progress, Completed"
								},
								{
									"key": "priority",
									"value": "All",
									"description": "All, Low, Medium, High"
								},
								{
									"key": "sortBy",
									"value": "dueDate:asc",
									"description": "Sorting options: dueDate:asc, dueDate:desc, createdAt:desc, title:asc"
								}
							]
						},
						"description": "Retrieves all tasks for the logged-in user. Supports search and filters by status and priority, as well as customizable sorting."
					},
					"response": []
				},
				{
					"name": "Create Task",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Read a book\",\n    \"description\": \"Read at least 20 pages of clean code principles\",\n    \"status\": \"Pending\",\n    \"priority\": \"High\",\n    \"dueDate\": \"2026-12-31\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/tasks",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tasks"
							]
						},
						"description": "Creates a new task associated with the logged-in user."
					},
					"response": []
				},
				{
					"name": "Get Single Task Details",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/tasks/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tasks",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "TASK_ID_HERE",
									"description": "The unique MongoDB ObjectID of the task"
								}
							]
						},
						"description": "Retrieves the full details of a specific task by its ID."
					},
					"response": []
				},
				{
					"name": "Update Task Details",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Read a book (Updated)\",\n    \"status\": \"In Progress\",\n    \"priority\": \"Medium\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/tasks/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tasks",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "TASK_ID_HERE",
									"description": "The unique MongoDB ObjectID of the task"
								}
							]
						},
						"description": "Updates any set of attributes on an existing task (e.g. status, title, description, due date)."
					},
					"response": []
				},
				{
					"name": "Delete Task",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/tasks/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tasks",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "TASK_ID_HERE",
									"description": "The unique MongoDB ObjectID of the task"
								}
							]
						},
						"description": "Permanently deletes a task by its ID."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
